@page
@model TourCompany.Pages.RegisterModel
@{
}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<form method="post">
	<div class="border p-3 mt-4 mb-5">
		<div asp-validation-summary="All" class="text-danger"></div>
		<div class="row pb-2">
			<h2 class="text-primary pl-3">
				Register
			</h2>
		</div>
		<div class="mb-3">
			<label asp-for="Register.Firstname"></label>
			<input asp-for="Register.Firstname" class="form-control" />
			<span asp-validation-for="Register.Firstname" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="Register.Lastname"></label>
			<input asp-for="Register.Lastname" class="form-control" />
			<span asp-validation-for="Register.Lastname" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="Register.Phone"></label>
			<input asp-for="Register.Phone" class="form-control" />
			<span asp-validation-for="Register.Phone" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="Register.EmailAddress"></label>
			<input asp-for="Register.EmailAddress" class="form-control" />
			<span asp-validation-for="Register.EmailAddress" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="Register.Password"></label>
			<input asp-for="Register.Password" class="form-control" />
			<span asp-validation-for="Register.Password" class="text-danger"></span>
		</div>
		<div class="mb-3">
			<label asp-for="Register.ConfirmPassword"></label>
			<input asp-for="Register.ConfirmPassword" class="form-control" />
			<span asp-validation-for="Register.ConfirmPassword" class="text-danger"></span>
		</div>


		<a asp-page="Login">Already Have An Account: Sign In</a><br />

		<button type="submit" class="btn btn-primary">Register</button>
	</div>
</form>

@section Scripts {
	@{
		<partial name="_validationScriptsPartial" />
		
	}
}
<script>
	$("#Login").html("");
</script>

