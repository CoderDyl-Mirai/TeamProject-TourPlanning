@page
@model TourCompany.Pages.Customers.Home.DetailsModel
@{
}
<div class="">
    <form method="post">

        <div class="container backgroundWhite">
            <div class="card">
                <div class="card-header">
                    <div class="text-light ml-0 row ">
                        <div class="col-12 col-md-6 pt-2">
                            <h1 class="text-primary">@Model.Tour.Name</h1>
                        </div>
                        <div class="col-12 col-md-6 text-end pt-2">
                            <h1 class="text-muted">€@Model.Tour.Price</h1>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="container rounded p-2">
                        <div class="row">
                            <div class="col-12 col-lg-8">
                                <div class="row">

                                    <div class="col-12">
                                        <h3 class="text-success"></h3>

                                        <p class="text-secondary">@Model.Tour.Description</p>
                                        <p class="text-secondary">Date & Time: @Model.Tour.Date</p>
                                        <p class="text-secondary">Location: @Model.Tour.Location</p>
                                        <p class="text-secondary">Duration: @Model.Tour.Duration Minutes</p>
                                        <p class="text-secondary">Tickets Remaining: @Model.Tour.MaxCapacity</p>

                                        <div class="form-floating my-2">
                    
                                        </div>

                                    </div>

                                </div>
                            </div>
                            <div class="col-12 col-lg-4 p-1 text-center">
                                <img src="@Model.Tour.Image" width="100%" class="rounded" />
                            </div>


                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="row">
                        <div class="col-12 col-md-6 pb-1 ">
                            <a asp-page="Index" class="btn btn-success btn-square form-control" style="height:50px;">Back</a>
                        </div>
                        <div class="col-12 col-md-6 ">
                            <a asp-page="Booking" asp-route-id="@Model.Tour.Id" button type="submit" class="btn btn-primary btn-square form-control" style="height:50px;">Make Booking</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
