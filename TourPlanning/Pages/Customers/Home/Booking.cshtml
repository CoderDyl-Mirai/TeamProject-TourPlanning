@page
@model TourCompany.Pages.Customers.Home.BookingModel
@{
}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<form method="post">
        <input asp-for="Booking.TourId" hidden/>
		<input asp-for="Booking.CustomerId" hidden/>
    <!--<input asp-for="Booking.ApplicationUserId" hidden />-->
	<div class="border p-3 mt-4 mb-5">
		<div class="row pb-2">
			<h1 class="text-primary pl-3">@Model.Booking.Tour.Name</h1>
			<h2 class="text-primary pl-3">Make Booking</h2>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Customer.Firstname"></label>
			<input asp-for="@Model.Customer.Firstname" class="form-control" />
			<span asp-validation-for="@Model.Customer.Firstname" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Customer.Lastname"></label>
			<input asp-for="@Model.Customer.Lastname" class="form-control" />
			<span asp-validation-for="@Model.Customer.Lastname" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Customer.Email"></label>
			<input asp-for="@Model.Customer.Email" class="form-control" />
			<span asp-validation-for="@Model.Customer.Email" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Booking.Date"></label>
			<input value="" asp-for="@Model.Booking.Date"
				   type="datetime-local"
				   id="date"
				   class="form-control"
				   min="@DateTime.Now.AddHours(1).AddMinutes(-DateTime.Now.Minute).AddSeconds(-DateTime.Now.Second).ToString("yyyy-MM-ddTHH:mm")" 
				   max="@DateTime.Now.AddMonths(6).AddMinutes(-DateTime.Now.Minute).AddSeconds(-DateTime.Now.Second).ToString("yyyy-MM-ddTHH:mm")"
				   step="3600" />
			<!-- step="3600" = 1 hour intervals -->
			<span asp-validation-for="@Model.Booking.Date" class="text-danger"></span>
		</div>
		

		<div class="mb-3">
			<label asp-for="@Model.Booking.TicketAmount"></label>
			<input asp-for="@Model.Booking.TicketAmount" id = "ticketAmount" class="form-control" />
			<span asp-validation-for="@Model.Booking.TicketAmount" class="text-danger"></span>
		</div>
		
			@foreach (var extra in Model.Extras)
			{
			<div class="form-check me-3">
				<input class="form-check-input"
					   type="checkbox"
					   name="choosenExtra" 
					   value=@extra.Id
					   data-price=@extra.Price
					   id="@extra.Id" />
				<label class="form-check-label" for="@extra.Id">
					@extra.Name €@extra.Price - @extra.Description
				</label>
			</div>
			}
		

		<div class="mb-3">
			<label asp-for="@Model.Booking.TotalPrice"></label>
			<input asp-for="@Model.Booking.TotalPrice" id="totalPrice" class="form-control" value="@Model.Booking.Tour.Price" />
			<span asp-validation-for="@Model.Booking.TotalPrice" class="text-danger"></span>
		</div>

		

		<button type="submit" id ="submit" class="btn btn-primary">Create</button>
		<a asp-page="Index" class="btn btn-secondary">Back</a>

	</div>
    </form>
	<script>

			function calculateTotal() {
		let totalPrice = @Model.Booking.Tour.Price * $("#ticketAmount").val();

		$('input[type="checkbox"]:checked').each(function () {
			totalPrice += parseFloat($(this).data("price"))* $("#ticketAmount").val();
		});

		$("#totalPrice").val(totalPrice);

		currentCap = 0
		console.log(bookings)
		bookings.forEach(function(booking){
			//console.log($("#date").val())
			date = booking.date.substring(0,16)
			//console.log(date)
			if(date === $("#date").val())
			{
				currentCap += booking.ticketAmount
			}
		})
		console.log(currentCap+Number($("#ticketAmount").val()))
		if(currentCap+Number($("#ticketAmount").val())>@Model.Booking.Tour.MaxCapacity)
		{
			$("#submit").prop("disabled",true);
		}
		else{
			$("#submit").prop("disabled",false);
		}
	}

	$("#ticketAmount").on("change", calculateTotal);
	$(".form-check-input").on("click", calculateTotal);

	
	var bookings = @Html.Raw(Json.Serialize(Model.BookingsOfTour));


	var $dateInput = $('#date');

	function snapToHour(value) {
		if (!value) return value;
		var parts = value.split('T');
		var datePart = parts[0];
		var hour = parts[1].split(':')[0];
		return datePart + 'T' + hour.padStart(2, '0') + ':00';
	}

		// Snap on page load
	$dateInput.val(snapToHour($dateInput.val()));

		// Snap whenever user changes the input
	$dateInput.on('input change', function() {
		$(this).val(snapToHour($(this).val()));

		currentCap = 0
		console.log(bookings)
		bookings.forEach(function(booking){
			//console.log($("#date").val())
			date = booking.date.substring(0,16)
			//console.log(date)
			if(date === $("#date").val())
			{
				currentCap += booking.ticketAmount
			}
		})
		console.log(currentCap)
		console.log(currentCap+Number($("#ticketAmount").val()))


		if(currentCap+Number($("#ticketAmount").val())>@Model.Booking.Tour.MaxCapacity)
		{
			$("#submit").prop("disabled",true);
		}
		else{
			$("#submit").prop("disabled",false);
		}
	});
	
	</script>
