@page
@model TourCompany.Pages.Customers.Home.BookingModel
@{
}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<form method="post">
        <input asp-for="Booking.TourId" hidden/>
		<input asp-for="Booking.CustomerId" hidden/>
	<div class="border p-3 mt-4 mb-5">
		<div class="row pb-2">
			<h1 class="text-primary">@Model.Booking.Tour.Name</h1>
			<h2 class="text-primary">Make Booking</h2>
		</div>

		<div class="row">
			<!-- LEFT SIDE -->
			<div class="col-md-6">

				<div class="mb-3">
					<label asp-for="@Model.Booking.Date">Date (Must be between 9:00-19:00)</label>
					<input asp-for="@Model.Booking.Date"
						   type="date"
						   id="date"
						   class="form-control"
						   min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")"
						   max="@DateTime.Now.AddMonths(6).ToString("yyyy-MM-dd")" />
					<span asp-validation-for="@Model.Booking.Date" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="@Model.Booking.Time"></label>
					<select asp-for="@Model.Booking.Time" id="time" class="form-select">
						<option disabled selected>Select Time</option>
						<option>09:00</option>
						<option>10:00</option>
						<option>11:00</option>
						<option>12:00</option>
						<option>13:00</option>
						<option>14:00</option>
						<option>15:00</option>
						<option>16:00</option>
						<option>17:00</option>
						<option>18:00</option>
						<option>19:00</option>

					</select>
					<span asp-validation-for="@Model.Booking.Date" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="@Model.Booking.TicketAmount"></label>
					<input asp-for="@Model.Booking.TicketAmount" id="ticketAmount" class="form-control" min="1"/>
					<span asp-validation-for="@Model.Booking.TicketAmount" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="@Model.Booking.TotalPrice"></label>
					<input asp-for="@Model.Booking.TotalPrice" value="@Model.Booking.Tour.Price" id="totalPrice" class="form-control" readonly />
					<span asp-validation-for="@Model.Booking.TotalPrice" class="text-danger"></span>
				</div>

				<br />
				<div class="mb-3">
					<h5>Extras</h5>

					@foreach (var extra in Model.Extras)
					{
						<div class="form-check">
							<input class="form-check-input"
								   type="checkbox"
								   name="choosenExtra"
								   value="@extra.Id"
								   data-price="@extra.Price"
								   id="@extra.Id" />
							<label class="form-check-label" for="@extra.Id">
								@extra.Name €@extra.Price - @extra.Description
							</label>
						</div>
					}
				</div>

			</div>

			<!-- RIGHT SIDE  -->
			<div class="col-md-6">
				<br />
				<img src="@Model.Booking.Tour.BookingImage" class="img-fluid rounded mb-3" style="height: 300px; width: 80%;" />
			</div>
		</div>

		<div class="mt-3">
			<button type="submit" id="submit" class="btn btn-primary">Pay</button>
			<a asp-page="Index" class="btn btn-secondary">Back</a>
		</div>
	</div>
    </form>
	<script>

			function calculateTotal() {
				
		let totalPrice = @Model.Booking.Tour.Price * $("#ticketAmount").val();

		$('input[type="checkbox"]:checked').each(function () {
			totalPrice += parseFloat($(this).data("price"))* $("#ticketAmount").val();
		});

		$("#totalPrice").val(totalPrice);

		currentCap = 0
		console.log(bookings)
		bookings.forEach(function(booking){
			//console.log($("#date").val())
			date = booking.date
			time = booking.time

			//console.log(date)
			if (booking.status == "Confirmed")
			{
				if(date === $("#date").val() && time === $('#time option:selected').text())
				{
					currentCap += booking.ticketAmount
				}
			}

			

		})
		console.log(currentCap+Number($("#ticketAmount").val()))
		if(currentCap+Number($("#ticketAmount").val())>@Model.Booking.Tour.MaxCapacity)
		{
			$("#submit").prop("disabled",true);
			alert("Ticket amount chosen puts tour over capacity")
			$("#ticketAmount").val(@Model.Booking.Tour.MaxCapacity-currentCap)
		}
		else{
			$("#submit").prop("disabled",false);
		}
	}
	$("#ticketAmount").on("change", calculateTotal);
	$(".form-check-input").on("click", calculateTotal);

	
	var bookings = @Html.Raw(Json.Serialize(Model.BookingsOfTour));

	var $dateInput = $('#date');

	
		// Snap on page load
	//$dateInput.val(snapToHour($dateInput.val()));

		// Snap whenever user changes the input
	$dateInput.on('input change', function() {
		//$(this).val(snapToHour($(this).val()));

		currentCap = 0
		console.log(bookings)
		bookings.forEach(function(booking){
			//console.log($("#date").val())
			date = booking.date.substring(0,16)
			//console.log(date)
			if(date === $("#date").val())
			{
				currentCap += booking.ticketAmount
			}
		})
		console.log(currentCap)
		console.log(currentCap+Number($("#ticketAmount").val()))


		if(currentCap+Number($("#ticketAmount").val())>@Model.Booking.Tour.MaxCapacity)
		{
			$("#submit").prop("disabled",true);
			alert("Ticket amount chosen puts tour over capacity")

		}
		else{
			$("#submit").prop("disabled",false);
		}
	});


	
	</script>
	@section Scripts{
	<script src="https://js.stripe.com/v3/"></script>
	}
