@page
@model TourCompany.Pages.Customers.Home.IndexModel
@{
}
<div class="row container pb-3 backgroundWhite">

	<p>
		<form class="d-flex" class="col-3">
			<input type="text" placeholder="Enter Tour Name" class="form-control me-sn-2" asp-for="SearchString"/>
			<input type="submit" value="Search" class="btn btn-outline" class="form-control align-content-end"/>
			<a asp-route-Tours="" asp-route-SearchString="" class="btn btn-outline-secondary">Clear</a>
		</form>
	</p>
	<br /><br /><br />



	@foreach (var location in Model.listOfTours.GroupBy(t => t.Location))
	{
		<h2 class="text-info pl-1"><b>@location.Key</b></h2>
		<div class="col-12">
			<div class="row my-3">
				@foreach (var tour in location)
				{
					<div class="col-lg-4 col-md-6 pb-4 filter">
						<div class="card bg-white rounded shadow-sm" style="border:1px solid #222">
							<div class="card-body pb-1 row">
								<div class="col-8 h5">@tour.Name</div>
								<div class="col-4 text-end"><span class="text-info h4">€@tour.Price</span></div>
							</div>
							<img class="card-img-top img-fluid d-block mx-auto mb-3" src="@tour.Image" alt="menuitem image">
							<div class="card-body p-1 px-3 row">
								<div class="col-12 pt-2" style="font-size:13px; text-align:justify">
									<p>@tour.Description</p>
								</div>
								<div class="col-12 p-1">
									<a asp-page="Booking" asp-route-id="@tour.Id" class="btn btn-dark
									form-control btn-sm p-2" style="height:40px">View Details</a>
								</div>
							</div>
						</div>
					</div>
				}
			</div>
		</div>
	}
</div>	

