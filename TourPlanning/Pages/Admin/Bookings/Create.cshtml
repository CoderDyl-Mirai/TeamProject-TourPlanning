@page
@model TourCompany.Pages.Admin.Bookings.CreateModel
@{
}
<form method="post" enctype="multipart/form-data">
	<div class="border p-3 mt-4 mb-5">
		<div class="row pb-2">
			<h2 class="text-primary pl-3">Create New Tour</h2>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Booking.TicketAmount">Amount Of Tickets</label>
			<input asp-for="@Model.Booking.TicketAmount" class="form-control" />
			<span asp-validation-for="@Model.Booking.TicketAmount" class="text-danger"></span>
		</div>

		<button type="submit" class="btn btn-primary">Create</button>
		<a asp-page="Index" class="btn btn-secondary">Back to Index</a>

	</div>
</form>
@section Scripts {
	@{
		<partial name="_validationScriptsPartial"></partial>
	}
}

