@page
@model TourCompany.Pages.Admin.Tours.IndexModel
@{
}
<h3 class="text-primary">Tours</h3>

<br /> <br /> <br />

<table>
	<thead>
		<tr>
			<th>Available Tours</th>
		</tr>
	</thead>
	<tbody>
		@foreach(var obj in Model.Tours)
		{
			<tr>
				<td width="50%">@obj.Name</td>
			</tr>
		}
	</tbody>
</table>
