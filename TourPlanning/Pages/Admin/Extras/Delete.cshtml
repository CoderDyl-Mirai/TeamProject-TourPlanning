@page
@model TourCompany.Pages.Admin.Extras.DeleteModel
@{
}
<form method="post" enctype="multipart/form-data">
	<input hidden asp-for="Extra.Id" />
	<div class="border p-3 mt-4">
		<div class="row pb-2">
			<h2 class="text-primary pl-3">Create New Tour</h2>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Extra.Name"></label>
			<input asp-for="@Model.Extra.Name" class="form-control" />
			<span asp-validation-for="@Model.Extra.Name" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Extra.Description"></label>
			<textarea asp-for="@Model.Extra.Description" class="form-control" rows="5"></textarea>
			<span asp-validation-for="@Model.Extra.Description" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Extra.Price"></label>
			<input asp-for="@Model.Extra.Price" class="form-control" />
			<span asp-validation-for="@Model.Extra.Price" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="@Model.Extra.TourId"></label>
			<input asp-for="@Model.Extra.TourId" class="form-control" />
			<span asp-validation-for="@Model.Extra.TourId" class="text-danger"></span>
		</div>
	</div>
	<button type="submit" class="btn btn-primary">Delete</button>
	<a asp-page="Index" class="btn btn-secondary">Back</a>
	</div>
</form>
@section Scripts {
	@{
		<partial name="_validationScriptsPartial"></partial>
	}
}
