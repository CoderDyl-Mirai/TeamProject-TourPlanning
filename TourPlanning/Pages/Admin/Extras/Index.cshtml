@page
@model TourCompany.Pages.Admin.Extras.IndexModel
@{
}
<div class="container p-3">
	<div class="row pt-4">
		<div class="col-6">
			<h3 class="text-primary">Available Extras</h3>
		</div>
		<div class="col-6">
			<a asp-page="Create" class="btn btn-primary">
				Create new Extra
			</a>
		</div>
	</div>

</div>

<br />

<table class="table table-bordered table-striped">
	<thead>
		<tr>
			<th>Name</th>
			<th>Description</th>
			<th>Price</th>
            <th>Tour ID</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var obj in Model.Extras)
		{
			<tr>
				<td width="10%">@obj.Name</td>
				<td width="20%">@obj.Description</td>
				<td width="8%">@obj.Price</td>
                <td width="8%">@obj.TourId</td>

				<td>
					<a asp-page="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2">Edit</a>
				</td>
				<td>
					<a asp-page="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2">Delete</a>
				</td>
			</tr>
		}
	</tbody>
</table>


