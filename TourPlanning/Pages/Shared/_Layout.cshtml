@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Terrific Tours</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bootstrapLux.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TourCompany.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Terrific Tours</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                    </ul>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="dropdown d-flex flex-row mb-3">
                                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    AdminMenu
                                </button>
                                        <ul class="dropdown-menu">
                                            <li><a class="dropdown-item text-bg-dark" href="/Admin/Customers/Index">Customer</a></li>
                                            <li><a class="dropdown-item text-bg-dark" href="/Admin/Bookings/Index">Bookings</a></li>
                                            <li><a class="dropdown-item text-bg-dark" href="/Admin/Tours/Index">Tours</a></li>
                                            <li><a class="dropdown-item text-bg-dark" href="/Admin/Extras/Index">Extras</a></li>
                                            <li><a class="dropdown-item text-bg-dark" href="/Admin/BookingExtras/Index">BookingExtras</a></li>
                                        </ul>

                                <a class="btn btn-outline-secondary" asp-area="" asp-page="/Logout">Logout</a>

                            </div>
                        }
                        else
                        {
                            <div class="dropdown d-flex flex-row mb-3">
                                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Menu
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item text-bg-dark" href="/Customers/Home/Profile">My Account</a></li>
                                </ul>
                                <a class="btn btn-outline-secondary" asp-area="" asp-page="/Logout">Logout</a>
                            </div>

                        }

                    }
                    else
                    {
                        <ul id = "Login" class="navbar-nav flex-grow-1 justify-content-end">
                            <li class="nav-item m-4">
                                <a class="btn btn-primary" asp-area="" asp-page="/Login">Login</a>
                            </li>
                            <li class="nav-item m-4">
                                <a class="btn btn-outline-secondary" asp-area="" asp-page="/Register">Register</a>
                            </li>
                        </ul>
                    }

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted bg-primary">
        <div class="container">
            &copy; 2026 - TourCompany 
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
